    // Commissions: The Ledger (Read-only for Influencers, Admin full control)
    match /commissions/{commId} {
      allow read: if isAdmin() || (isInfluencer() && resource.data.influencerId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Withdrawals: Influencers create/read own, Admins manage
    match /withdrawals/{withdrawId} {
      allow create: if isInfluencer();
      allow read: if isAdmin() || (isInfluencer() && resource.data.influencerId == request.auth.uid);
      allow update: if isAdmin();
    }

    // Audit Logs: Strictly Admin
    match /auditLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // Products: Public read, Admin write
    match /products/{prodId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings & Config
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
